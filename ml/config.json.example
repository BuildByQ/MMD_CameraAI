{
  "data": {
        "normalized_dir": "data/normalization_params",
        "train_songs": [],
        "test_songs": [TITLE_HERE],
        "prediction_csv": "outputs/predict.csv"
    },
  "training": {
      "batch_size": 16,
      "epochs": 8,
      "learning_rate": 0.0005,
      "weight_decay": 0.00001,
      "shuffle": true,
      "device": "cpu",
      "save_interval": 12,
      "resume": false
  },
  "output_dir": "models",
  "camera_features": [
    "pos_x","pos_y","pos_z","rot_x_speed","rot_x_sin","rot_x_cos","rot_y_speed","rot_y_sin","rot_y_cos","rot_z_speed","rot_z_sin","rot_z_cos","distance","fov"
  ],
  "motion_features": [
    "グルーブ_w_x",
    "グルーブ_w_y",
    "グルーブ_w_z",
    "センター_w_x",
    "センター_w_y",
    "センター_w_z",
    "上半身_w_x",
    "上半身_w_y",
    "上半身_w_z",
    "上半身2_w_x",
    "上半身2_w_y",
    "上半身2_w_z",
    "下半身_w_x",
    "下半身_w_y",
    "下半身_w_z",
    "右つま先ＩＫ_w_x",
    "右つま先ＩＫ_w_y",
    "右つま先ＩＫ_w_z",
    "右ひざ_w_x",
    "右ひざ_w_y",
    "右ひざ_w_z",
    "右ひじ_w_x",
    "右ひじ_w_y",
    "右ひじ_w_z",
    "右手首_w_x",
    "右手首_w_y",
    "右手首_w_z",
    "右目_w_x",
    "右目_w_y",
    "右目_w_z",
    "右腕_w_x",
    "右腕_w_y",
    "右腕_w_z",
    "右足_w_x",
    "右足_w_y",
    "右足_w_z",
    "右足首_w_x",
    "右足首_w_y",
    "右足首_w_z",
    "右足ＩＫ_w_x",
    "右足ＩＫ_w_y",
    "右足ＩＫ_w_z",
    "左つま先ＩＫ_w_x",
    "左つま先ＩＫ_w_y",
    "左つま先ＩＫ_w_z",
    "左ひざ_w_x",
    "左ひざ_w_y",
    "左ひざ_w_z",
    "左ひじ_w_x",
    "左ひじ_w_y",
    "左ひじ_w_z",
    "左手首_w_x",
    "左手首_w_y",
    "左手首_w_z",
    "左目_w_x",
    "左目_w_y",
    "左目_w_z",
    "左腕_w_x",
    "左腕_w_y",
    "左腕_w_z",
    "左足_w_x",
    "左足_w_y",
    "左足_w_z",
    "左足首_w_x",
    "左足首_w_y",
    "左足首_w_z",
    "左足ＩＫ_w_x",
    "左足ＩＫ_w_y",
    "左足ＩＫ_w_z",
    "腰_w_x",
    "腰_w_y",
    "腰_w_z",
    "頭_w_x",
    "頭_w_y",
    "頭_w_z",
    "首_w_x",
    "首_w_y",
    "首_w_z",
    "head_front_w_x",
    "head_front_w_y",
    "head_front_w_z",
    "upper_body_front_w_x",
    "upper_body_front_w_y",
    "upper_body_front_w_z",
    "lower_body_front_w_x",
    "lower_body_front_w_y",
    "lower_body_front_w_z"
  ],

  "audio_features": [
    "mfcc_0","mfcc_1","mfcc_2","mfcc_3","mfcc_4","mfcc_5","mfcc_6","mfcc_7","mfcc_8","mfcc_9","mfcc_10","mfcc_11","mfcc_12","mel_0","mel_1","mel_2","mel_3","mel_4","mel_5","mel_6","mel_7","mel_8","mel_9","spectral_centroid","spectral_bandwidth","spectral_rolloff","zero_crossing_rate"
  ],
  
  "labels_features": ["target_head_front","target_head_back","target_head_focused_strict","target_head_focused","target_head_focused_loose","event_eye_contact","target_body_front","target_body_back","target_body_focused_strict","target_body_focused","target_body_focused_loose","target_leg_front","target_leg_back","target_leg_focused_strict","target_leg_focused","target_leg_focused_loose","height_high","height_mid","height_low","tilt_up","tilt_flat","tilt_down","is_rolled","prox_close","prox_mid","prox_far","event_cut","dyn_move_low","dyn_move_mid","dyn_move_high","dyn_rot_low","dyn_rot_mid","dyn_rot_high","dyn_zoom_in","dyn_zoom_out","dyn_zoom_low","dyn_zoom_mid","dyn_zoom_high"],
  "label_groups": {
      "target": [
        "prob_target_head_focused_strict", "prob_target_head_focused", "prob_target_head_focused_loose",
        "prob_target_body_focused_strict", "prob_target_body_focused", "prob_target_body_focused_loose",
        "prob_target_leg_focused_strict", "prob_target_leg_focused", "prob_target_leg_focused_loose"
      ],
      "height": ["prob_height_high", "prob_height_mid", "prob_height_low"],
      "tilt": ["prob_tilt_up", "prob_tilt_flat", "prob_tilt_down"],
      "proximity": ["prob_prox_close", "prob_prox_mid", "prob_prox_far"],
      "dynamics": ["prob_dyn_move_high", "prob_dyn_rot_high", "prob_dyn_zoom_high"]
  },
  "model": {
    "seq_len": 11,
    "hidden_size": 256,
    "num_layers": 2,
    "dropout": 0.2,
    "bidirectional": false
  },
    "postprocess": {
      "tilt_scale": 1.2,
      "pan_scale": 0.8,
      "zoom_scale": 1.1,
      "change_scale": 0.7,
      "smooth_window": 5,
      "target_change_points_per_10s": 5
  },
    "bias_settings": {
        "bin_target_leg_focused": 0.0,
        "bin_prox_far": 0.0,
        "bin_target_head_focused": -0.0
  }
}